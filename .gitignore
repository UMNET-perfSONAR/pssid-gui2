build/
node_modules/
log

# Ignore all output files except provision.sh as this comes by default so that
# the application can be used out of the box. Users have the choice of using their
# own provision.sh.
services/server/output/*
!services/server/output/provision.sh
services/server/.env
/certs/*
**/certs/*
services/client/certs/*
mongo-backups/*
*.crt
*.key
*.pem
*.env

test-docker-compose.yml
services/database/init-mongo.js

# Installer-generated artifacts (host-specific, not for version control)
.env
.env.bak
nginx.conf.bak
www/

# Site-specific Ansible inventories (copied from remote.example.ini)
ansible/inventories/remote.ini
# macOS folder metadata, never commit
.DS_Store

# The repo-root shared/ directory is staged into each service's src/shared at
# build time (Docker COPY, CI, and the `sync:shared` npm script). The copies are
# generated — the originals live in /shared.
services/client/src/shared/
services/server/src/shared/
