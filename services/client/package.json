{
  "name": "client",
  "private": true,
  "version": "3.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -p tsconfig.build.json && vite build",
    "typecheck": "vue-tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "sync:shared": "node -e \"const fs=require('fs'),s='../../shared';fs.existsSync(s)&&fs.cpSync(s,'src/shared',{recursive:true})\"",
    "predev": "npm run sync:shared",
    "prebuild": "npm run sync:shared",
    "pretypecheck": "npm run sync:shared",
    "pretest": "npm run sync:shared"
  },
  "dependencies": {
    "@formkit/themes": "^0.18.0-7d9b8a6",
    "@formkit/vue": "^0.18.0-7d9b8a6",
    "@jsonforms/vue": "^3.0.0",
    "@jsonforms/vue-vanilla": "^3.1.0",
    "@vue-js-cron/core": "^3.7.1",
    "@vue-js-cron/vuetify": "^3.3.3",
    "axios": "^1.4.0",
    "bootstrap": "^4.6.0",
    "pinia": "^2.1.4",
    "vue": "^3.2.47",
    "vue-multiselect": "^3.0.0-beta.2",
    "vue-router": "^4.2.2",
    "vuetify": "^3.3.8"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.1.0",
    "http-server": "14.1.1",
    "jsdom": "^24.1.3",
    "typescript": "^5.0.2",
    "vite": "^4.3.0",
    "vitest": "^1.6.1",
    "vue-tsc": "^1.2.0"
  },
  "license": "Apache-2.0",
  "description": "pSSID GUI client"
}
