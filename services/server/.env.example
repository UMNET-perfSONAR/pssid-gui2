# MongoDB connection string. In Docker Compose this points to the mongo service.
MONGODB_URI=mongodb://mongo:27017/pssid

# Redis connection string. Required when ENABLE_SSO=true (redis profile).
REDIS_URL=redis://redis:6379

# --- SSO / OIDC (required when ENABLE_SSO=true in shared/config.ts) ---

# The base URL of your OIDC identity provider's authorization server.
# Use the issuer whose discovery document is at
# <ISSUER_BASE_URL>/.well-known/openid-configuration.
ISSUER_BASE_URL=https://idp.example.com

# The public URL of this pSSID GUI deployment (no trailing slash).
# Used for the OIDC redirect URI and CORS origin.
# Example: https://pssid-gui.example.edu
BASE_URL=https://pssid-gui.example.edu

# The hostname only (no https://) for the session cookie domain.
# Must match the hostname in BASE_URL.
# Example: pssid-gui.example.edu
COOKIE_DOMAIN=pssid-gui.example.edu

# OIDC client ID issued by your identity provider.
CLIENT_ID=your-client-id-here

# OIDC client secret issued by your identity provider.
CLIENT_SECRET=your-client-secret-here

# Random secret used to sign session cookies. Use a long random string (32+ chars).
# Generate one with: openssl rand -hex 32
SECRET=replace-with-a-long-random-string
